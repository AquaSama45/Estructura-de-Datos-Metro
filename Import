import json
import unicodedata
import networkx as nx



# Normalización y aliases

ARTICULOS = {"el", "la", "los", "las", "de", "del", "un", "una"}

ALIAS_MANUALES: dict[str, list[str]] = {
    "Pabellón del Agua EPM": ["Pabellón"],
    "Ciudadela Universitaria": ["Ciudadela"],
    "U. de M.": ["udm"],
}

def normalizar(texto: str) -> str:
    """Minúsculas, sin tildes, sin espacios laterales."""
    texto = texto.lower().strip()
    texto = unicodedata.normalize("NFD", texto)
    return "".join(c for c in texto if unicodedata.category(c) != "Mn")

def generar_aliases(nombre: str) -> list[str]:
    """
    Devuelve todas las variantes normalizadas de un nombre de estación:
      - Con espacios            → "la estrella"
      - Sin espacios            → "laestrella"
      - Sin artículo inicial    → "estrella"
      - Sin artículo ni espacio → "estrella"  (igual al anterior en este caso)
    Solo se eliminan artículos/preposiciones al inicio (el, la, los, las, de, del…).
    Palabras como 'san', 'santa', 'parque'… NO se eliminan.
    """
    base = normalizar(nombre)           # "la estrella"
    sin_espacios = base.replace(" ", "") # "laestrella"

    alias = {base, sin_espacios}

    # Quitar artículo inicial si lo hay
    palabras = base.split()
    if len(palabras) > 1 and palabras[0] in ARTICULOS:
        sin_art = " ".join(palabras[1:])        # "estrella"
        alias.add(sin_art)
        alias.add(sin_art.replace(" ", ""))     # por si quedan varias palabras

    return list(alias)

# Cargar el JSON

JSON_PATH = "Metro_Medellin_SITVA.json"

with open(JSON_PATH, encoding="utf-8") as f:
    data = json.load(f)

print(f"Sistema : {data['sistema']}")
print(f"Fuente  : {data['fuente']}")
print(f"Líneas  : {len(data['lineas'])}\n")

# Construir el grafo

G = nx.Graph()
indice: dict[str, str] = {}   # alias_normalizado → nombre real en el grafo

for linea in data["lineas"]:
    clave      = linea["clave"]
    tipo       = linea["tipo"]
    estaciones = linea["estaciones"]

    for est in estaciones:
        nombre = est["nombre"]

        if nombre not in G:
            G.add_node(
                nombre,
                municipio = est["municipio"],
                lat       = est["latitud"],
                lon       = est["longitud"],
                lineas    = [],
            )
            # Registrar todos los alias de este nodo
            for alias in generar_aliases(nombre):
                indice.setdefault(alias, nombre)   # primero en llegar gana

             # Alias manuales para nombres específicos sin modificar el JSON
            for alias in ALIAS_MANUALES.get(nombre, []):
                alias_norm = normalizar(alias)
                indice.setdefault(alias_norm.replace(" ", ""), nombre)
                indice.setdefault(alias_norm, nombre)

        if clave not in G.nodes[nombre]["lineas"]:
            G.nodes[nombre]["lineas"].append(clave)

    for i in range(len(estaciones) - 1):
        origen  = estaciones[i]["nombre"]
        destino = estaciones[i + 1]["nombre"]
        dist_km = estaciones[i]["dist_sig_km"]

        if dist_km is not None:
            G.add_edge(origen, destino, weight=dist_km, linea=clave, tipo=tipo)

# ─── Tarifas 2026 (COP) ──────────────────────────────────────────────────────
# Fuente: Metro de Medellín — tarifas vigentes 2026
TARIFAS_2026 = {
    "Metro":          3_550,   # Líneas A y B (metro pesado)
    "Tranvía":        5_550,   # Línea T (integrada con metro)
    "MetroPlus":      3_550,   # Líneas 1, 2 y O (BRT / Bus Eléctrico)
    "Cable":          3_550,   # Líneas K, L, J, H, M, P (cables aéreos)
    "BusElectrico":          3_550,   # Líneas O (Bus Eléctrico)
    
}
# Tipo de cada línea
TIPO_LINEA = {}

for linea in data['lineas']:
    TIPO_LINEA[linea['clave']] = linea['tipo']
    
def calcular_costo(ruta: list[str], G: nx.Graph) -> tuple[int, list[str]]:
    """
    Calcula el costo total del viaje considerando trasbordos.

    Regla tarifaria integrada del sistema SITVA:
      - Se paga UN solo viaje (tarifa base) al entrar al sistema.
      - Cada trasbordo entre líneas de DISTINTO tipo tarifario
        genera un cobro adicional.
      - Transbordos dentro del mismo tipo (p. ej. Metro A → Metro B)
        NO generan cobro extra.
      - Si viajas en una sola línea sin cambiar, NO se cobra trasbordo
        aunque la estación intermedia pertenezca también a otra línea.

    Retorna:
      (costo_total_COP, lista de descripciones de cobros)
    """
    if len(ruta) < 1:
        return 0, []

    cobros: list[str] = []
    costo_total: int  = 0

    def tipo_linea_estacion(nombre: str) -> str:
        """Tipo según prioridad de las líneas de la estación (fallback)."""        
        lineas = G.nodes[nombre].get("lineas", [])
        for prioridad in ("Metro", "Tranvía", "MetroPlus", "Cable"):
            for l in lineas:
                if TIPO_LINEA.get(l) == prioridad:
                    return prioridad
        return "Metro"

    # Tipo de la primera arista (línea con la que se inicia el viaje)
    if len(ruta) >= 2:
        datos_arista = G.edges[ruta[0], ruta[1]]
        primera_linea = datos_arista.get("linea")
        tipo_actual = TIPO_LINEA.get(primera_linea, tipo_linea_estacion(ruta[0]))
    else:
        tipo_actual = tipo_linea_estacion(ruta[0])

    tarifa_entrada = TARIFAS_2026[tipo_actual]
    costo_total += tarifa_entrada
    cobros.append(f"Entrada en {ruta[0]} ({tipo_actual}): ${tarifa_entrada:,}")

    # Recorre la ruta usando la línea de CADA ARISTA recorrida
    for i in range(1, len(ruta)):
        if i < len(ruta) - 1:
            # Línea de la arista que sale de ruta[i] hacia ruta[i+1]
            datos_arista = G.edges[ruta[i], ruta[i + 1]]
            linea_sig = datos_arista.get("linea")
            tipo_siguiente = TIPO_LINEA.get(linea_sig, tipo_linea_estacion(ruta[i]))
        else:
            # Última estación: usamos la línea de la arista que llegó aquí
            datos_arista = G.edges[ruta[i - 1], ruta[i]]
            linea_sig = datos_arista.get("linea")
            tipo_siguiente = TIPO_LINEA.get(linea_sig, tipo_linea_estacion(ruta[i]))

        if tipo_siguiente != tipo_actual:
            tarifa_trasbordo = TARIFAS_2026[tipo_siguiente]
            costo_total += tarifa_trasbordo
            cobros.append(
                f"Trasbordo en {ruta[i]} "
                f"({tipo_actual} → {tipo_siguiente}): ${tarifa_trasbordo:,}"
            )
            tipo_actual = tipo_siguiente

    return costo_total, cobros


# Función de búsqueda 

def buscar_nodo(entrada: str) -> str | None:
    """Devuelve el nombre real del nodo o None si no existe."""
    return indice.get(normalizar(entrada).replace(" ", "")) \
        or indice.get(normalizar(entrada))

# Consulta

print("── Ruta más corta (Dijkstra por km) ────────────────────────────────────")
origen_input  = input("Origen  : ")
destino_input = input("Destino : ")

origen_nodo  = buscar_nodo(origen_input)
destino_nodo = buscar_nodo(destino_input)

if origen_nodo is None:
    print(f"  ✗ Estación no encontrada: '{origen_input}'")
elif destino_nodo is None:
    print(f"  ✗ Estación no encontrada: '{destino_input}'")
else:
    try:
        ruta = nx.shortest_path(G, origen_nodo, destino_nodo, weight="weight")
        dist = nx.shortest_path_length(G, origen_nodo, destino_nodo, weight="weight")

        # Calcular costo del viaje
        costo_total, cobros = calcular_costo(ruta, G)

        print(f"  {origen_nodo} → {destino_nodo}")
        print(f"  Distancia : {dist:.2f} km")
        print(f"  Paradas   : {len(ruta)}  |  Costo estimado: ${costo_total:,} COP")
        print()
        print("  Detalle de cobros:")
        for cobro in cobros:
            print(f"    · {cobro}")
        print()
        print(f"  Ruta: {' → '.join(ruta)}")
    except nx.NetworkXNoPath:
        print(f"  ✗ No hay camino entre {origen_nodo} y {destino_nodo}")